# Providers
LLM_PROVIDER=groq
QUEUE_PROVIDER=valkey
STORAGE_PROVIDER=minio

# LLM
GROQ_API_KEY=
CLAUDE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Base de datos
DATABASE_URL=postgresql+asyncpg://softlab:softlab@localhost:5432/softlab

# Valkey
VALKEY_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=softlab-artifacts

# Análisis
SANDBOX_TIMEOUT=300
MAX_PROJECT_SIZE_MB=500
RAG_MAX_TOKENS=6000
RAG_CONFIDENCE_THRESHOLD=0.70

# Scoring
WEIGHT_SECURITY=0.25
WEIGHT_STATIC=0.20
WEIGHT_ARCHITECTURE=0.20
WEIGHT_TESTING=0.20
WEIGHT_PERFORMANCE=0.15

# API
SECRET_KEY=dev-secret-key-cambiar-en-produccion
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
